# Public URL (no trailing slash) — used in Stripe redirects and emails
NEXT_PUBLIC_URL=https://claimgap.app

# Anthropic (server-side only)
ANTHROPIC_API_KEY=

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Required for API routes (webhook, analyze, admin) — get from Supabase project settings
SUPABASE_SERVICE_ROLE_KEY=
# Optional: only for `npm run db:apply` (create tables). Database → Connection string → URI (includes DB password)
# DATABASE_URL=

# Stripe — server routes use STRIPE_SECRET_KEY only (must start with sk_test_ or sk_live_)
# Do not paste the publishable pk_ key here. No extra quotes/spaces. Same Test/Live mode as Dashboard.
# Cloudflare Pages: set vars for Production (and Preview if you test deploys there), then redeploy.
STRIPE_SECRET_KEY=
# Optional — only if you add Elements/client-side Stripe later
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Webhook signing secret (whsec_…) from Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=

# Resend — verify a sending domain in Resend and set a verified from address
RESEND_API_KEY=
RESEND_FROM_EMAIL="ClaimGap <noreply@yourdomain.com>"

# Admin dashboard: https://claimgap.app/admin/login
# Comma-separated emails allowed to sign in
ADMIN_EMAILS=akatogarov@gmail.com,info@globaldeal.app
# Shared password for admin login (rotate if leaked)
ADMIN_SECRET=
# Random string for signing admin session cookies (e.g. openssl rand -hex 32)
ADMIN_JWT_SECRET=
